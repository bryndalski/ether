{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lokówka",
  "version": "0.1.0",
  "identifier": "com.bryndalski.lokowka",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lokówka",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "public.app-category.developer-tools",
    "copyright": "© 2026 Jakub Bryndal",
    "shortDescription": "Local-first API client with curl under the hood",
    "longDescription": "Lokówka is a local-first API client that runs curl under the hood. Compose, send, and inspect HTTP and GraphQL requests from a native macOS desktop app — no cloud, no telemetry, your requests stay on your machine.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
