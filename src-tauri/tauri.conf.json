{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ether",
  "version": "0.2.0",
  "identifier": "com.bryndalski.ether",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Ether",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "public.app-category.developer-tools",
    "copyright": "© 2026 Jakub Bryndal",
    "shortDescription": "Local-first API client — requests into the void",
    "longDescription": "Ether is a local-first API client that runs curl under the hood. Compose, send, and inspect HTTP and GraphQL requests from a native macOS desktop app — requests go into the void, nothing escapes your machine: no cloud, no telemetry.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "dmg": {
        "background": "dmg/background.png",
        "windowSize": {
          "width": 660,
          "height": 420
        },
        "appPosition": {
          "x": 165,
          "y": 210
        },
        "applicationFolderPosition": {
          "x": 495,
          "y": 210
        }
      }
    }
  }
}
